#!/usr/bin/env bash
set -euo pipefail

# Clyde - Docker Container for Claude Code
# Launches Claude Code in an isolated container with the current directory mounted

VERSION="2.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="${CLYDE_IMAGE:-clyde:local}"
DOCKER_DIR="${CLYDE_DOCKER_DIR:-$SCRIPT_DIR/../docker}"

# Default resource limits (can be overridden via environment or flags)
MEMORY_LIMIT="${CLYDE_MEMORY:-8g}"
CPU_LIMIT="${CLYDE_CPUS:-4}"

# Profile management
PROFILES_DIR="$HOME/.claude/profiles"
PROFILE="${CLYDE_PROFILE:-}"

# Nix-related configuration
NIX_STORE_VOLUME="${CLYDE_NIX_STORE_VOLUME:-clyde-nix-store}"
NPM_CACHE_VOLUME="${CLYDE_NPM_CACHE_VOLUME:-clyde-npm-cache}"
NIX_VERBOSE="${CLYDE_NIX_VERBOSE:-0}"

# Flags
FORCE_BUILD=false
NO_GIT="${CLYDE_NO_GIT:-}"
NIX_GC=false
LIST_PACKAGES=false

# Container debugging options
SHELL_MODE="${CLYDE_SHELL:-false}"
X11_ENABLED="${CLYDE_X11:-false}"
EXEC_COMMAND=()

# Arguments to pass to Claude Code
CLAUDE_ARGS=()

# Cleanup tracking
CLEANUP_FILES=()

##############################################################################
# Functions
##############################################################################

usage() {
    cat <<EOF
Usage: clyde [OPTIONS] [-- CLAUDE_ARGS...]

Launch Claude Code in an isolated Docker container with the current directory mounted.
Packages are managed via Nix for reproducibility; Claude Code is always latest via npm.

Options:
    --memory <SIZE>        Container memory limit (default: 8g)
    --cpus <NUM>           Container CPU limit (default: 4)
    --build                Force rebuild of the Docker image
    --no-git               Skip mounting ~/.gitconfig and SSH agent forwarding
    --shell                Launch interactive bash shell instead of Claude Code
    --x11                  Enable X11 forwarding for graphical applications
    --exec <COMMAND>       Execute a command in the container and exit
    -h, --help             Display this help message
    -v, --version          Display version information

Nix Options:
    --nix-verbose          Show full Nix output during environment setup
    --nix-gc               Garbage collect unused packages from Nix store
    --list-packages        Show packages that would be available (without starting session)

Profile Options:
    -P, --profile <NAME>   Use specified profile for authentication
    --add-profile <NAME>   Create a new profile (interactive)
    --delete-profile <NAME> Delete an existing profile
    --list-profiles        List available profiles
    --set-default <NAME>   Set the default profile

Environment Variables:
    CLYDE_MEMORY           Default memory limit (overridden by --memory)
    CLYDE_CPUS             Default CPU limit (overridden by --cpus)
    CLYDE_NO_GIT           If set to 1, skip git/SSH mounts
    CLYDE_IMAGE            Custom image name (default: clyde:local)
    CLYDE_PROFILE          Default profile to use (overridden by --profile)
    CLYDE_DOCKER_DIR       Path to docker directory (default: script_dir/../docker)
    CLYDE_NIX_VERBOSE      Show full Nix output if set to 1
    CLYDE_NIX_STORE_VOLUME Named Docker volume for /nix (default: clyde-nix-store)
    CLYDE_NPM_CACHE_VOLUME Named Docker volume for npm global (default: clyde-npm-cache)
    CLYDE_SHELL            If set to true/1, launch shell instead of Claude Code
    CLYDE_X11              If set to true/1, enable X11 forwarding

Nix Configuration:
    Project-specific: Place flake.nix or shell.nix in your project root
    User-global:      Place flake.nix or shell.nix in ~/.config/clyde/
    Default:          Uses built-in packages (git, gh, node, curl, ssh)

Examples:
    clyde                           Launch in current directory
    clyde --memory 16g --cpus 8     Custom resource limits
    clyde --build                   Force rebuild the image
    clyde -- --resume               Pass --resume to Claude Code
    clyde --nix-verbose             Debug Nix environment setup
    clyde --nix-gc                  Clean up unused Nix packages
    clyde --list-packages           Preview available packages
    clyde --shell                   Interactive shell for debugging
    clyde --x11 --shell             Shell with X11 forwarding
    clyde --exec cargo test         Run command in container and exit
    clyde --x11 --exec xclock       Run graphical app in container

Profile Examples:
    clyde --add-profile pro         Create 'pro' profile with OAuth token
    clyde --profile pro             Launch using 'pro' profile
    clyde --set-default pro         Set 'pro' as default profile
    CLYDE_PROFILE=max clyde         Use 'max' profile via environment

EOF
}

version() {
    echo "clyde version $VERSION"
}

error() {
    echo "Error: $1" >&2
    exit "${2:-1}"
}

info() {
    echo "$1" >&2
}

warn() {
    echo "Warning: $1" >&2
}

validate_x11() {
    if [[ -z "${DISPLAY:-}" ]]; then
        error "X11 forwarding requested but DISPLAY is not set.
Set DISPLAY or run from a graphical session." 7
    fi
    # Check if X11 socket exists (warn if not, but don't fail - SSH X11 forwarding uses TCP)
    local display_num="${DISPLAY#:}"
    display_num="${display_num%%.*}"
    if [[ ! -S "/tmp/.X11-unix/X${display_num}" ]] && [[ ! -S "/tmp/.X11-unix/X0" ]]; then
        warn "X11 socket not found at expected location. X11 may not work."
    fi
}

# Cleanup function for temporary files
cleanup() {
    for file in "${CLEANUP_FILES[@]}"; do
        if [[ -f "$file" ]]; then
            # Use shred if available for secure deletion
            if command -v shred &>/dev/null; then
                shred -u "$file" 2>/dev/null || rm -f "$file"
            else
                rm -f "$file"
            fi
        fi
    done
}
trap cleanup EXIT

##############################################################################
# Profile Management
##############################################################################

# Validate profile name to prevent path traversal attacks
validate_profile_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        error "Invalid profile name '$name'. Use only alphanumeric characters, dash, and underscore." 6
    fi
    if [[ ${#name} -gt 64 ]]; then
        error "Profile name too long (max 64 characters)." 6
    fi
}

ensure_profiles_dir() {
    if [[ ! -d "$PROFILES_DIR" ]]; then
        # Create parent directories first, then profiles dir with secure permissions
        mkdir -p "$(dirname "$PROFILES_DIR")"
        mkdir -m 700 "$PROFILES_DIR"
    fi
}

get_default_profile() {
    local default_file="$PROFILES_DIR/.default"
    if [[ -f "$default_file" ]]; then
        cat "$default_file"
    else
        echo ""
    fi
}

set_default_profile() {
    local name="$1"
    validate_profile_name "$name"
    local profile_file="$PROFILES_DIR/${name}.json"

    if [[ ! -f "$profile_file" ]]; then
        error "Profile '$name' does not exist" 6
    fi

    ensure_profiles_dir
    echo "$name" > "$PROFILES_DIR/.default"
    info "Default profile set to '$name'"
}

get_profile_token() {
    local name="$1"
    validate_profile_name "$name"
    local profile_file="$PROFILES_DIR/${name}.json"

    if [[ ! -f "$profile_file" ]]; then
        error "Profile '$name' does not exist. Run 'clyde --add-profile $name' to create it." 6
    fi

    if ! command -v jq &>/dev/null; then
        error "jq is required for profile management. Install with: apt install jq" 1
    fi

    jq -r '.token' "$profile_file"
}

list_profiles() {
    ensure_profiles_dir
    local default_profile
    default_profile=$(get_default_profile)

    local found=false
    for profile_file in "$PROFILES_DIR"/*.json; do
        if [[ -f "$profile_file" ]]; then
            found=true
            local name
            name=$(basename "$profile_file" .json)
            local description=""

            if command -v jq &>/dev/null; then
                description=$(jq -r '.description // ""' "$profile_file")
            fi

            if [[ "$name" == "$default_profile" ]]; then
                echo "* $name (default)${description:+ - $description}"
            else
                echo "  $name${description:+ - $description}"
            fi
        fi
    done

    if [[ "$found" == false ]]; then
        info "No profiles found. Run 'clyde --add-profile NAME' to create one."
    fi
}

save_profile() {
    local name="$1"
    local token="$2"
    local description="${3:-}"

    validate_profile_name "$name"
    local profile_file="$PROFILES_DIR/${name}.json"

    ensure_profiles_dir

    local created_at
    created_at=$(date -Iseconds)

    cat > "$profile_file" <<EOF
{
  "name": "$name",
  "token": "$token",
  "description": "$description",
  "createdAt": "$created_at"
}
EOF
    chmod 600 "$profile_file"
    info "Profile '$name' saved."

    # Clear sensitive variables from memory
    token=""
    description=""
}

add_profile() {
    local name="$1"

    validate_profile_name "$name"
    local profile_file="$PROFILES_DIR/${name}.json"

    if [[ -f "$profile_file" ]]; then
        error "Profile '$name' already exists. Delete it first with 'clyde --delete-profile $name'" 6
    fi

    if ! command -v jq &>/dev/null; then
        error "jq is required for profile management. Install with: apt install jq" 1
    fi

    ensure_profiles_dir

    echo "Creating profile: $name"
    echo ""
    echo "You'll need an OAuth token from Claude Code."
    echo ""
    echo "To get a token, run 'claude setup-token' on your host system."
    echo "This will open a browser for authentication and output a token."
    echo ""

    # Check if we can extract from existing credentials
    local credentials_file="$HOME/.claude/.credentials.json"
    if [[ -f "$credentials_file" ]]; then
        local existing_token
        existing_token=$(jq -r '.claudeAiOauth.accessToken // empty' "$credentials_file" 2>/dev/null || true)
        if [[ -n "$existing_token" ]]; then
            echo "Found existing OAuth token in ~/.claude/.credentials.json"
            read -rp "Use this token for profile '$name'? [Y/n] " use_existing
            if [[ "${use_existing:-Y}" =~ ^[Yy]$ ]]; then
                read -rp "Description (optional): " description
                save_profile "$name" "$existing_token" "$description"
                # Clear token from memory
                existing_token=""

                # Set as default if it's the first profile
                if [[ -z "$(get_default_profile)" ]]; then
                    set_default_profile "$name"
                fi
                return 0
            fi
            # Clear token from memory even if not used
            existing_token=""
        fi
    fi

    echo ""
    read -rp "Paste your OAuth token: " token

    if [[ -z "$token" ]]; then
        error "Token cannot be empty" 6
    fi

    read -rp "Description (optional): " description

    save_profile "$name" "$token" "$description"
    # Clear token from memory
    token=""
    description=""

    # Set as default if it's the first profile
    if [[ -z "$(get_default_profile)" ]]; then
        set_default_profile "$name"
    fi
}

delete_profile() {
    local name="$1"

    validate_profile_name "$name"
    local profile_file="$PROFILES_DIR/${name}.json"

    if [[ ! -f "$profile_file" ]]; then
        error "Profile '$name' does not exist" 6
    fi

    read -rp "Delete profile '$name'? [y/N] " confirm
    if [[ ! "${confirm:-N}" =~ ^[Yy]$ ]]; then
        info "Cancelled."
        return 0
    fi

    # Use shred for secure deletion if available
    if command -v shred &>/dev/null; then
        shred -u "$profile_file" 2>/dev/null || rm -f "$profile_file"
    else
        rm -f "$profile_file"
    fi
    info "Profile '$name' deleted."

    # Clear default if this was the default profile
    local default_profile
    default_profile=$(get_default_profile)
    if [[ "$default_profile" == "$name" ]]; then
        rm -f "$PROFILES_DIR/.default"
        info "Default profile cleared."
    fi
}

##############################################################################
# Validation
##############################################################################

validate_memory_limit() {
    local value="$1"
    if [[ ! "$value" =~ ^[0-9]+[bkmgBKMG]?$ ]]; then
        error "Invalid memory limit '$value'. Use format like 8g, 512m, 1024k." 4
    fi
}

validate_cpu_limit() {
    local value="$1"
    if [[ ! "$value" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        error "Invalid CPU limit '$value'. Use a number like 4 or 2.5." 4
    fi
}

check_docker() {
    if ! docker info &>/dev/null; then
        cat >&2 <<EOF
Error: Docker is not running or not installed.
Please start Docker and try again.
EOF
        exit 2
    fi
}

check_working_directory() {
    if [[ "$PWD" == "/" ]]; then
        cat >&2 <<EOF
Error: Cannot run clyde from root filesystem (/).
Please change to a project directory first.
EOF
        exit 5
    fi
}

##############################################################################
# Image Management
##############################################################################

build_image() {
    if [[ ! -d "$DOCKER_DIR" ]]; then
        error "Docker directory not found at $DOCKER_DIR" 3
    fi

    info "Building Clyde image..."
    if ! docker build -t "$IMAGE_NAME" "$DOCKER_DIR"; then
        cat >&2 <<EOF
Error: Failed to build Clyde image.
Check the build output above for details.
EOF
        exit 3
    fi
    info "Image built successfully."
}

ensure_image() {
    if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
        info "Clyde image not found. Building (first run)..."
        build_image
    fi
}

##############################################################################
# Argument Parsing
##############################################################################

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                version
                exit 0
                ;;
            --memory)
                if [[ -z "${2:-}" ]]; then
                    error "Option --memory requires a value" 4
                fi
                validate_memory_limit "$2"
                MEMORY_LIMIT="$2"
                shift 2
                ;;
            --cpus)
                if [[ -z "${2:-}" ]]; then
                    error "Option --cpus requires a value" 4
                fi
                validate_cpu_limit "$2"
                CPU_LIMIT="$2"
                shift 2
                ;;
            --build)
                FORCE_BUILD=true
                shift
                ;;
            --no-git)
                NO_GIT=1
                shift
                ;;
            --nix-verbose)
                NIX_VERBOSE=1
                shift
                ;;
            --nix-gc)
                NIX_GC=true
                shift
                ;;
            --list-packages)
                LIST_PACKAGES=true
                shift
                ;;
            -P|--profile)
                if [[ -z "${2:-}" ]]; then
                    error "Option --profile requires a name" 4
                fi
                validate_profile_name "$2"
                PROFILE="$2"
                shift 2
                ;;
            --add-profile)
                if [[ -z "${2:-}" ]]; then
                    error "Option --add-profile requires a name" 4
                fi
                add_profile "$2"
                exit 0
                ;;
            --delete-profile)
                if [[ -z "${2:-}" ]]; then
                    error "Option --delete-profile requires a name" 4
                fi
                delete_profile "$2"
                exit 0
                ;;
            --list-profiles)
                list_profiles
                exit 0
                ;;
            --set-default)
                if [[ -z "${2:-}" ]]; then
                    error "Option --set-default requires a profile name" 4
                fi
                set_default_profile "$2"
                exit 0
                ;;
            --shell)
                SHELL_MODE=true
                shift
                ;;
            --x11)
                X11_ENABLED=true
                shift
                ;;
            --exec)
                shift
                if [[ $# -eq 0 ]]; then
                    error "Option --exec requires a command" 4
                fi
                EXEC_COMMAND=("$@")
                break  # Stop parsing; rest is the command
                ;;
            --)
                shift
                CLAUDE_ARGS=("$@")
                break
                ;;
            -*)
                error "Unknown option: $1" 4
                ;;
            *)
                error "Unexpected argument: $1" 4
                ;;
        esac
    done

    # Mutual exclusivity check: --shell and --exec cannot be used together
    if [[ "$SHELL_MODE" == true ]] && [[ ${#EXEC_COMMAND[@]} -gt 0 ]]; then
        error "Options --shell and --exec are mutually exclusive" 4
    fi

    # Warning: --shell with -- CLAUDE_ARGS doesn't make sense
    if [[ "$SHELL_MODE" == true ]] && [[ ${#CLAUDE_ARGS[@]} -gt 0 ]]; then
        warn "Option --shell ignores Claude arguments after --"
    fi
}

##############################################################################
# Nix Package Listing
##############################################################################

list_available_packages() {
    # Show what packages would be available without starting a full session
    info "Packages available in this environment:"
    echo ""

    # Check for project config
    if [[ -f "$PWD/flake.nix" ]]; then
        echo "Project packages (from $PWD/flake.nix):"
        echo "  [Detected - packages will be shown at container start]"
        echo ""
    elif [[ -f "$PWD/shell.nix" ]]; then
        echo "Project packages (from $PWD/shell.nix):"
        echo "  [Detected - packages will be shown at container start]"
        echo ""
    fi

    # Check for user config
    if [[ -f "$HOME/.config/clyde/flake.nix" ]]; then
        echo "User packages (from ~/.config/clyde/flake.nix):"
        echo "  [Detected - packages will be shown at container start]"
        echo ""
    elif [[ -f "$HOME/.config/clyde/shell.nix" ]]; then
        echo "User packages (from ~/.config/clyde/shell.nix):"
        echo "  [Detected - packages will be shown at container start]"
        echo ""
    fi

    echo "Default packages (always available):"
    echo "  - claude (Claude Code CLI - latest via npm)"
    echo "  - node / npm (Node.js 20 LTS)"
    echo "  - git (version control)"
    echo "  - gh (GitHub CLI)"
    echo "  - curl (HTTP client)"
    echo "  - ssh (SSH client)"
    echo ""

    info "Run 'clyde' to start and see all resolved packages."
}

##############################################################################
# Docker Run Construction
##############################################################################

run_container() {
    local docker_args=()

    # Interactive TTY
    docker_args+=(-it)

    # Remove container after exit
    docker_args+=(--rm)

    # Resource limits
    docker_args+=(--memory="$MEMORY_LIMIT")
    docker_args+=(--cpus="$CPU_LIMIT")

    # Host network mode (required for arbitrary API access)
    docker_args+=(--network host)

    # Pass host UID/GID for permission matching
    docker_args+=(-e "HOST_UID=$(id -u)")
    docker_args+=(-e "HOST_GID=$(id -g)")

    # Mount Nix store volume for package caching
    docker_args+=(-v "$NIX_STORE_VOLUME:/nix")

    # Mount npm cache volume for Claude Code installation
    docker_args+=(-v "$NPM_CACHE_VOLUME:/home/claude/.npm-global")

    # Pass Nix-related environment variables
    docker_args+=(-e "CLYDE_NIX_VERBOSE=$NIX_VERBOSE")
    if [[ "$NIX_GC" == true ]]; then
        docker_args+=(-e "CLYDE_NIX_GC=1")
    fi

    # Profile-based token authentication via mounted secret file
    # (Avoids exposing token in docker inspect or /proc/environ)
    local active_profile="$PROFILE"
    if [[ -z "$active_profile" ]]; then
        active_profile=$(get_default_profile)
    fi

    if [[ -n "$active_profile" ]]; then
        local token
        token=$(get_profile_token "$active_profile")
        if [[ -n "$token" ]]; then
            # Create secure temp file for token
            local token_file
            token_file=$(mktemp)
            chmod 600 "$token_file"
            echo -n "$token" > "$token_file"
            # Clear token from memory
            token=""

            # Track for cleanup
            CLEANUP_FILES+=("$token_file")

            # Mount as read-only secret
            docker_args+=(-v "$token_file:/run/secrets/oauth_token:ro")
            docker_args+=(-e "CLAUDE_CODE_OAUTH_TOKEN_FILE=/run/secrets/oauth_token")
            info "Using profile: $active_profile"
        fi
    fi

    # Mount current working directory at the same path inside container
    docker_args+=(-v "$PWD:$PWD")
    docker_args+=(-w "$PWD")

    # Mount Claude credentials directory (create if missing)
    local claude_home="$HOME/.claude"
    if [[ ! -d "$claude_home" ]]; then
        info "Note: No existing Claude credentials found."
        info "You will be prompted to authenticate on first use."
        mkdir -p "$claude_home"
    fi
    docker_args+=(-v "$claude_home:/home/claude/.claude")

    # Mount Claude config file (contains onboarding state, theme, etc.)
    local claude_json="$HOME/.claude.json"
    if [[ -f "$claude_json" ]]; then
        docker_args+=(-v "$claude_json:/home/claude/.claude.json")
    fi

    # Mount git config and forward SSH agent unless --no-git
    # Security: We forward SSH_AUTH_SOCK instead of mounting ~/.ssh directly
    # This keeps private keys on the host; only the agent socket is exposed
    if [[ -z "$NO_GIT" ]]; then
        if [[ -f "$HOME/.gitconfig" ]]; then
            docker_args+=(-v "$HOME/.gitconfig:/home/claude/.gitconfig:ro")
        fi
        # Forward SSH agent socket (preferred over mounting ~/.ssh)
        if [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -S "$SSH_AUTH_SOCK" ]]; then
            docker_args+=(-v "$SSH_AUTH_SOCK:/ssh-agent:ro")
            docker_args+=(-e "SSH_AUTH_SOCK=/ssh-agent")
        elif [[ -d "$HOME/.ssh" ]]; then
            # Fallback warning: agent not available, SSH won't work in container
            warn "SSH agent not running. Git SSH operations will not work in container."
            warn "Start ssh-agent and add keys with: eval \$(ssh-agent) && ssh-add"
        fi
    fi

    # Mount GitHub CLI config directory for authentication
    if [[ -d "$HOME/.config/gh" ]]; then
        docker_args+=(-v "$HOME/.config/gh:/home/claude/.config/gh:ro")
    fi

    # Mount user's local bin directory for additional tools
    if [[ -d "$HOME/.local/bin" ]]; then
        docker_args+=(-v "$HOME/.local/bin:/home/claude/.local/bin:ro")
        docker_args+=(-e "PATH=/home/claude/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin")
    fi

    # Mount user's Nix configuration directory if exists
    if [[ -d "$HOME/.config/clyde" ]]; then
        docker_args+=(-v "$HOME/.config/clyde:/home/claude/.config/clyde:ro")
        # Detect user flake or shell.nix
        if [[ -f "$HOME/.config/clyde/flake.nix" ]]; then
            docker_args+=(-e "CLYDE_USER_FLAKE=/home/claude/.config/clyde")
        elif [[ -f "$HOME/.config/clyde/shell.nix" ]]; then
            docker_args+=(-e "CLYDE_USER_SHELL=/home/claude/.config/clyde/shell.nix")
        fi
    fi

    # Detect project Nix configuration in current directory
    if [[ -f "$PWD/flake.nix" ]]; then
        docker_args+=(-e "CLYDE_PROJECT_FLAKE=$PWD")
        # Mount flake.lock if exists (read-only for reproducibility)
        if [[ -f "$PWD/flake.lock" ]]; then
            docker_args+=(-v "$PWD/flake.lock:$PWD/flake.lock:ro")
        fi
    elif [[ -f "$PWD/shell.nix" ]]; then
        docker_args+=(-e "CLYDE_PROJECT_SHELL=$PWD/shell.nix")
    fi

    # X11 forwarding if enabled
    if [[ "$X11_ENABLED" == true ]]; then
        docker_args+=(-v "/tmp/.X11-unix:/tmp/.X11-unix:rw")
        docker_args+=(-e "DISPLAY=$DISPLAY")

        # Mount host fonts for GUI applications
        if [[ -d "/usr/share/fonts" ]]; then
            docker_args+=(-v "/usr/share/fonts:/usr/share/fonts:ro")
        fi
        if [[ -d "$HOME/.local/share/fonts" ]]; then
            docker_args+=(-v "$HOME/.local/share/fonts:/home/claude/.local/share/fonts:ro")
        fi
        if [[ -d "$HOME/.fonts" ]]; then
            docker_args+=(-v "$HOME/.fonts:/home/claude/.fonts:ro")
        fi
        # Mount fontconfig cache for faster font loading
        if [[ -d "/var/cache/fontconfig" ]]; then
            docker_args+=(-v "/var/cache/fontconfig:/var/cache/fontconfig:ro")
        fi
    fi

    # Determine the command to run in the container
    if [[ "$SHELL_MODE" == true ]]; then
        # Shell mode: launch interactive bash
        exec docker run "${docker_args[@]}" "$IMAGE_NAME" bash
    elif [[ ${#EXEC_COMMAND[@]} -gt 0 ]]; then
        # Exec mode: run specified command
        exec docker run "${docker_args[@]}" "$IMAGE_NAME" "${EXEC_COMMAND[@]}"
    else
        # Default: run Claude Code with any passed arguments
        exec docker run "${docker_args[@]}" "$IMAGE_NAME" "${CLAUDE_ARGS[@]}"
    fi
}

##############################################################################
# Main
##############################################################################

main() {
    parse_args "$@"

    # Handle --list-packages (doesn't need docker)
    if [[ "$LIST_PACKAGES" == true ]]; then
        list_available_packages
        exit 0
    fi

    # Validation checks
    check_docker
    check_working_directory

    # Image management
    if [[ "$FORCE_BUILD" == true ]]; then
        build_image
    else
        ensure_image
    fi

    # Validate X11 if enabled
    if [[ "$X11_ENABLED" == true ]]; then
        validate_x11
    fi

    # Run the container
    run_container
}

main "$@"
